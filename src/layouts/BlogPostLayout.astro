---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/ads/AdSlot.astro';
import '../styles/prose.css';
import { formatDate } from '../lib/date';
import { CATEGORIES, SITE_URL } from '../consts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, category, tags, author } = post.data;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Person', name: author },
  publisher: { '@type': 'Organization', name: 'Syncarion' },
  mainEntityOfPage: `${SITE_URL}/blog/${post.slug}/`,
};
---

<BaseLayout
  title={`${title} — Syncarion`}
  description={description}
  ogType="article"
  article={{ pubDate: pubDate.toISOString(), author }}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <article class="blog-post">
    <div class="container">
      <header class="post-header">
        <div class="post-meta-top">
          <a href={`/blog/category/${category}`} class="category-link">
            {CATEGORIES[category].label}
          </a>
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        </div>
        <h1>{title}</h1>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        )}
      </header>
      <div class="prose">
        <slot />
      </div>
      <AdSlot slot="post-bottom" format="horizontal" />
      {updatedDate && (
        <p class="updated-note">
          마지막 수정: {formatDate(updatedDate)}
        </p>
      )}
      <footer class="post-footer">
        <a href="/blog" class="back-link">&larr; 블로그 목록으로</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: 160px 0 80px;
  }

  .post-header {
    margin-bottom: 48px;
    max-width: 680px;
  }

  .post-meta-top {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    font-size: 0.875rem;
  }

  .category-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 4px 12px;
    border: 1px solid var(--color-accent);
    transition: all 0.2s;
  }

  .category-link:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  time {
    color: var(--color-text-muted);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .post-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8125rem;
    color: var(--color-text-dim);
  }

  .updated-note {
    margin-top: 48px;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-footer {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-size: 0.9375rem;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }
</style>
