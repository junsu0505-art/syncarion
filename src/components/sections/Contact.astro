---
// Contact section — form + channels
---

<section class="contact" id="contact">
  <div class="container">
    <div class="section-label">Contact</div>
    <h2 class="section-title">시작은 대화부터</h2>
    <p class="section-desc">
      "우리 사업에 AI를 어떻게 쓸 수 있을까?" —<br>
      이 질문 하나면 충분합니다. 무료 진단 상담을 신청하세요.
    </p>
    <div class="contact-grid">
      <form class="contact-form" id="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label for="name">이름 / 회사명</label>
            <input type="text" id="name" name="name" required placeholder="홍길동 / (주)회사명">
          </div>
          <div class="form-group">
            <label for="email">이메일</label>
            <input type="email" id="email" name="email" required placeholder="hello@company.com">
          </div>
        </div>
        <div class="form-group">
          <label for="type">관심 서비스</label>
          <select id="type" name="type">
            <option value="진단">AI 진단 — 어디부터 시작할지 알고 싶어요</option>
            <option value="구축">시스템 구축 — 만들어야 할 게 있어요</option>
            <option value="유지보수">운영 유지보수 — 기존 시스템 관리가 필요해요</option>
            <option value="기타">기타 — 이야기를 나눠보고 싶어요</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">현재 상황을 간단히 알려주세요</label>
          <textarea id="message" name="message" placeholder="예: 쇼핑몰을 운영 중인데, 고객 문의 응대와 상품 설명 작성에 시간이 너무 많이 듭니다."></textarea>
        </div>
        <div class="form-submit">
          <button type="submit" class="btn-primary">무료 진단 상담 신청 →</button>
        </div>
        <p class="form-note">24시간 이내 회신 드립니다</p>
      </form>
      <div class="contact-info">
        <h3>다른 방법으로<br>연락하셔도 됩니다</h3>
        <p>
          폼 작성이 번거로우시다면,<br>
          편한 채널로 연락 주세요.
        </p>
        <div class="contact-channels">
          <div class="channel">
            <div class="channel-icon">💬</div>
            <div class="channel-text">
              <span>카카오톡</span>
              <a href="https://open.kakao.com/o/sflud6ni" target="_blank">오픈채팅 바로가기</a>
            </div>
          </div>
          <div class="channel">
            <div class="channel-icon">✉️</div>
            <div class="channel-text">
              <span>이메일</span>
              <a href="mailto:hello@syncarion.com">hello@syncarion.com</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      if (!btn) return;
      const originalText = btn.innerHTML;

      const formData = new FormData(form);
      const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        type: formData.get('type'),
        message: formData.get('message')
      };

      if (!data.name || !data.email) {
        btn.innerHTML = '이름과 이메일을 입력해주세요';
        btn.style.background = '#6e2a2a';
        setTimeout(() => { btn.innerHTML = originalText; btn.style.background = ''; }, 2000);
        return;
      }

      btn.innerHTML = '전송 중...';
      btn.disabled = true;

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const result = await response.json();

        if (response.ok && result.success) {
          btn.innerHTML = '신청 완료 ✓ 24시간 이내 회신 드립니다';
          btn.style.background = '#2a6e4a';
          form.reset();
        } else {
          throw new Error(result.error || '전송 실패');
        }
      } catch (err) {
        btn.innerHTML = '전송 실패 — 카카오톡으로 문의해주세요';
        btn.style.background = '#6e2a2a';
        console.error('Form submission error:', err);
      }

      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.background = '';
        btn.disabled = false;
      }, 4000);
    });
  }
</script>

<style>
  .contact {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }

  .contact-info h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    margin-bottom: 24px;
  }

  .contact-info > p {
    color: var(--color-text-dim);
    margin-bottom: 48px;
    font-size: 1rem;
  }

  .contact-channels {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .channel {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .channel-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    font-size: 1rem;
    flex-shrink: 0;
  }

  .channel-text {
    font-size: 0.875rem;
  }

  .channel-text span {
    display: block;
    color: var(--color-text-dim);
    font-size: 0.75rem;
    margin-bottom: 2px;
  }

  .channel-text a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.3s;
  }

  .channel-text a:hover {
    color: var(--color-accent);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-dim);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    padding: 12px 16px;
    transition: border-color 0.3s;
    outline: none;
    -webkit-appearance: none;
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    border-color: var(--color-accent);
  }

  .form-group textarea {
    min-height: 120px;
    resize: vertical;
  }

  .form-group select {
    cursor: pointer;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-submit {
    margin-top: 8px;
  }

  .form-submit .btn-primary {
    width: 100%;
    justify-content: center;
  }

  .form-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
