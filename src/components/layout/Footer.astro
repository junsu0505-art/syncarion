---
// Footer component
// Extracted from legacy index.astro — Phase 1-2
---

<footer>
  <div class="container">
    <div class="footer-content">
      <div class="footer-left">
        &copy; {new Date().getFullYear()} Syncarion. All rights reserved.
      </div>
      <div class="footer-right">
        <a href="/about">소개</a>
        <a href="/privacy">개인정보처리방침</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding: 48px 0;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-left {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .footer-right {
    display: flex;
    gap: 24px;
  }

  .footer-right a {
    font-size: 0.8125rem;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer-right a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>
