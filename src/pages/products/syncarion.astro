---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductHero from '../../components/product/ProductHero.astro';
import { PRODUCTS } from '../../consts';

const product = PRODUCTS.find((p) => p.slug === 'syncarion')!;
---

<BaseLayout title={`${product.name} — Syncarion`} description={product.description}>
  <ProductHero product={product} />

  <section class="product-detail">
    <div class="container">
      <div class="detail-grid">
        <div class="detail-content">
          <h2>AI로 사업의 핵심을 재설계합니다</h2>
          <p>
            "AI를 도입하고 싶은데 어디서부터 시작해야 할지 모르겠다" —
            이 질문에 대한 답을 설계하고, 구축하고, 운영합니다.
          </p>
          <p>
            Syncarion은 단순한 외주 개발이 아닙니다.
            사업 구조를 이해하고, AI가 실제로 가치를 만드는 지점을 찾아
            시스템으로 구축합니다.
          </p>
        </div>
        <div class="detail-features">
          <h3>서비스 범위</h3>
          <ul>
            {product.features.map((f) => <li>{f}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="product-cta">
    <div class="container">
      <h2>시작은 대화부터</h2>
      <p>무료 진단 상담을 신청하세요. 24시간 이내 회신 드립니다.</p>
      <a href="/#contact" class="btn-primary">무료 진단 상담 →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .product-detail {
    padding: 80px 0;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .detail-content h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 24px;
  }

  .detail-content p {
    font-size: 1rem;
    color: var(--color-text-dim);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .detail-features h3 {
    font-size: 1.125rem;
    font-weight: 500;
    margin-bottom: 20px;
  }

  .detail-features ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .detail-features li {
    font-size: 0.9375rem;
    color: var(--color-text-dim);
    padding-left: 20px;
    position: relative;
  }

  .detail-features li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .product-cta {
    padding: 80px 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .product-cta h2 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 16px;
  }

  .product-cta p {
    color: var(--color-text-dim);
    margin-bottom: 32px;
  }

  @media (max-width: 768px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
