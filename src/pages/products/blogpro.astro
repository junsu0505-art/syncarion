---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductHero from '../../components/product/ProductHero.astro';
import { PRODUCTS } from '../../consts';

const product = PRODUCTS.find((p) => p.slug === 'blogpro')!;
---

<BaseLayout title={`${product.name} — Syncarion`} description={product.description}>
  <ProductHero product={product} />

  <section class="product-detail">
    <div class="container">
      <div class="detail-grid">
        <div class="detail-content">
          <h2>블로그 운영, AI에게 맡기세요</h2>
          <p>
            키워드 리서치부터 글 작성, 네이버 블로그 자동 발행까지.
            1인 운영자가 콘텐츠 마케팅에 쓰는 시간을 90% 줄여줍니다.
          </p>
          <p>
            Claude와 GPT를 결합한 AI 글 생성 엔진과
            Playwright 기반 자동 발행 시스템으로 구성됩니다.
          </p>
        </div>
        <div class="detail-features">
          <h3>주요 기능</h3>
          <ul>
            {product.features.map((f) => <li>{f}</li>)}
          </ul>
          <div class="status-note">
            <span class="label">현재 상태</span>
            <span>클로즈드 베타 운영 중 — 내부 블로그에서 실전 검증</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="product-cta">
    <div class="container">
      <h2>도입을 검토 중이신가요?</h2>
      <p>BlogPro 도입 상담이나 기술적 문의는 아래에서 연락해주세요.</p>
      <a href="/#contact" class="btn-primary">문의하기 →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .product-detail {
    padding: 80px 0;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .detail-content h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 24px;
  }

  .detail-content p {
    font-size: 1rem;
    color: var(--color-text-dim);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .detail-features h3 {
    font-size: 1.125rem;
    font-weight: 500;
    margin-bottom: 20px;
  }

  .detail-features ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .detail-features li {
    font-size: 0.9375rem;
    color: var(--color-text-dim);
    padding-left: 20px;
    position: relative;
  }

  .detail-features li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .status-note {
    padding: 16px 20px;
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
    color: var(--color-text-dim);
  }

  .status-note .label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 4px;
  }

  .product-cta {
    padding: 80px 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .product-cta h2 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 16px;
  }

  .product-cta p {
    color: var(--color-text-dim);
    margin-bottom: 32px;
  }

  @media (max-width: 768px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
