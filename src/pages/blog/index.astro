---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, type CategorySlug } from '../../consts';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = Object.entries(CATEGORIES) as [CategorySlug, typeof CATEGORIES[CategorySlug]][];
---

<BaseLayout title="블로그 — Syncarion" description="투자, 개발, 그리고 빌더의 일상. Syncarion 블로그.">
  <main class="blog-index">
    <div class="container">
      <header class="blog-header">
        <div class="section-label">Blog</div>
        <h1 class="section-title">배우고, 만들고, 기록합니다</h1>
        <p class="section-desc">투자 인사이트, 개발 경험, 그리고 1인 빌더의 작업실 일지.</p>
      </header>

      <nav class="category-nav">
        <a href="/blog" class="cat-link active">전체</a>
        {categories.map(([slug, info]) => (
          <a href={`/blog/category/${slug}`} class="cat-link">{info.label}</a>
        ))}
      </nav>

      <div class="post-list">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            slug={post.slug}
            featured={post.data.featured}
          />
        ))}
      </div>

      {posts.length === 0 && (
        <p class="empty">아직 게시된 글이 없습니다.</p>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .blog-index {
    padding: 160px 0 80px;
  }

  .blog-header {
    margin-bottom: 48px;
  }

  .category-nav {
    display: flex;
    gap: 8px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .cat-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    text-decoration: none;
    padding: 6px 16px;
    border: 1px solid var(--color-border);
    transition: all 0.2s;
    letter-spacing: 0.02em;
  }

  .cat-link:hover,
  .cat-link.active {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .empty {
    color: var(--color-text-muted);
    font-size: 1rem;
    padding: 48px 0;
  }
</style>
